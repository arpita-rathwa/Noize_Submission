# ============================================================
# NOIZE Backend — .env.example
# Copy to .env and fill in real values.
# NEVER commit .env to version control.
# ============================================================

# ── Auth (REQUIRED) ───────────────────────────────────────────
# Generate both with:
#   python -c "import secrets; print(secrets.token_hex(32))"
# Run the command TWICE — use different values for each key.
SECRET_KEY=CHANGE_THIS_TO_A_RANDOM_64_CHAR_HEX_STRING
REFRESH_SECRET_KEY=CHANGE_THIS_TO_A_DIFFERENT_RANDOM_64_CHAR_STRING

# ── ML Engine (REQUIRED) ──────────────────────────────────────
# The backend forwards CSV files here for bias analysis.
# Must match the port you start the ML engine on (default 8000).
# Docker: use http://ml:8000  |  Local dev: http://localhost:8000
ML_ENGINE_URL=http://localhost:8000

# ── Gemini API (REQUIRED for AI explanations) ─────────────────
# Free key at: https://aistudio.google.com → Get API Key
GEMINI_API_KEY=your-gemini-api-key-here

# ── Google OAuth (optional — only for /auth/google-login) ─────
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com

# ── Storage ───────────────────────────────────────────────────
UPLOAD_DIR=uploads
MAX_UPLOAD_MB=50

# ── Database ──────────────────────────────────────────────────
# Local dev: db.json flat file (auto-fallback when Firebase not set)
# Production: set FIREBASE_CREDENTIALS_JSON instead (see below)
DB_FILE=db.json

# ── Firebase Firestore (production) ──────────────────────────
# Option A — paste entire service account JSON as one line:
# FIREBASE_CREDENTIALS_JSON={"type":"service_account","project_id":"..."}
# Option B — path to downloaded key file (local dev):
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json
FIREBASE_PROJECT_ID=your-firebase-project-id

# ── Token expiry ──────────────────────────────────────────────
TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── CORS ──────────────────────────────────────────────────────
# Comma-separated list of allowed origins — NO trailing slashes.
# Local dev:   http://localhost:3000,http://localhost:8080
# Flutter web: add your Firebase Hosting URL here before demo day
#   e.g. https://noize-app.web.app,http://localhost:8080
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080
